import json
import re

def extract_prices(html_path):
    with open(html_path) as f:
        html = f.read()

    prices = []
    pattern = r"<span class="item-price"[^>]*data-value="([^"]*)"[^>]*>"
    for match in re.finditer(pattern, html):
        prices.append(match.group(1))
    return prices

