    def to_dict(self):
        return {
            "name": self.name,
            "email": self.email,
            "role": self.role,
            "created_at": self.created_at
        }

class Product:
    def __init__(self, name, price, category):
        self.name = name
        self.price = price
        self.category = category

    def to_dict(self):
        return {
            "name": self.name,
            "price": self.price,
            "category": self.category
        }
