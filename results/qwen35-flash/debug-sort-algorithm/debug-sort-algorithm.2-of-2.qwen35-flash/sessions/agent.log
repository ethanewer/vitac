[?2004l#!/usr/bin/env python3
def merge_sort(arr):
    if len(arr) <= 1: return list(arr)
    mid = len(arr) // 2
    return merge(merge_sort(arr[:mid]), merge_sort(arr[mid:]))
def merge(l, r):
    res, i, j = [], 0, 0
    while i < len(l) and j < len(r):
        if l[i] <= r[j]: res.append(l[i]); i += 1
        else: res.append(r[j]); j += 1
    res.extend(l[i:]); res.extend(r[j:])
    return res
if __name__ == "__main__":
    nums = [int(l.strip()) for l in open("/app/data/input.txt") if l.strip()]
    sn = merge_sort(nums)
    with open("/app/output/sorted.txt","w") as f:
        for n in sn: f.write(str(n)+"\n")
