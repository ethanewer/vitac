[?2004limport os
import re

def fix_filename(filename):
    pattern = r"(\\d{8})"
    match = re.search(pattern, filename)
    if not match:
        return None
    date_str = match.group(1)
    try:
        year = int(date_str[0:4])
        month = int(date_str[4:6])
        day = int(date_str[6:8])
        if month < 1 or month > 12 or day < 1 or day > 31:
            return None
    except ValueError:
        return None
    formatted_date = f"{year}-{month:02d}-{day:02d}"
    new_filename = filename.replace(date_str, "")
    new_filename = new_filename.strip("_\\.")
    new_filename = re.sub(r"[_\\.]+\\.+|\\.+[_\\.]+", "_", new_filename)
    new_filename = new_filename.strip("_")
    if not new_filename:
        new_filename = "unnamed"
    final_name = f"{formatted_date}_{new_filename}"
    return final_name

DATA_DIR = "/app/data/files/"
os.chdir(DATA_DIR)
for filename in os.listdir(DATA_DIR):
    if os.path.isfile(filename):
        new_name = fix_filename(filename)
        if new_name:
            old_path = os.path.join(DATA_DIR, filename)
            new_path = os.path.join(DATA_DIR, new_name)
            os.rename(old_path, new_path)
            print(f"Renamed: {filename} -> {new_name}")
