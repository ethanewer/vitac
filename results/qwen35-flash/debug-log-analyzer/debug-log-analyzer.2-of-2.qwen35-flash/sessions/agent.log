[?2004limport sys

log_file = "/app/data/app.log"
output_file = "/app/output/report.json"

lines = open(log_file).readlines()
total_lines = len(lines)

total_requests = 0
error_count = 0
sum_time = 0

for line in lines:
    if "completed in" in line:
        total_requests += 1
        ms = int(line.split("completed in ")[1].replace("ms", ""))
        sum_time += ms
    if "ERROR" in line:
        error_count += 1

avg_time = sum_time / total_requests if total_requests > 0 else 0

result = {
    "error_count": error_count,
    "avg_response_time_ms": avg_time,
    "total_requests": total_requests,
    "total_lines": total_lines
}

with open(output_file, "w") as f:
    import json
    json.dump(result, f, indent=2)
